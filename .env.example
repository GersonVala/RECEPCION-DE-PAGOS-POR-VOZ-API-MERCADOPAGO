# Mercado Pago - Access Token de producción
# Obtenerlo en: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=

# Puerto donde corre el servidor Flask (default: 5000)
FLASK_PORT=5000

# Clave secreta para las sesiones de Flask (usar una cadena larga y aleatoria)
FLASK_SECRET_KEY=

# Contraseña para acceder al dashboard web
DASHBOARD_PASSWORD=
